# Bumpers alpha cloud sync
#
# Local development works without these values. When these Supabase values are
# present, /api/cloud/saved-searches stores saved searches in Supabase instead
# of data/cloud-saved-searches.json.

BUMPERS_CLOUD_PROVIDER=supabase
BUMPERS_CLOUD_USER_ID=alpha
BUMPERS_CLOUD_USER_EMAIL=alpha@bumpers.local
BUMPERS_CLOUD_USER_NAME=Bumpers Alpha User
BUMPERS_REQUIRE_INVITE=false

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
