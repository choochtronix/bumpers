{
  "name": "bumpers",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first gear search radar for Japanese synth and pro audio listings.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "design:sync": "node scripts/sync-design-tokens.mjs",
    "design:check": "node scripts/design-system-check.mjs",
    "aeo:check": "node scripts/aeo-check.mjs",
